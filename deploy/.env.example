# ============================================================
# Foronum News Pipeline - Variables de entorno
# Copia este archivo a .env y ajusta los valores
# ============================================================

# --- n8n ---
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
GENERIC_TIMEZONE=Europe/Madrid
TZ=Europe/Madrid

# --- PostgreSQL (n8n interno) ---
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=cambia_esta_password

# --- n8n Auth ---
N8N_ENCRYPTION_KEY=cambia-esto-a-una-cadena-larga-aleatoria-de-32-chars
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# --- MySQL (pipeline local / dev) ---
MYSQL_ROOT_PASSWORD=cambia_esta_password
MYSQL_DATABASE=foronum_n8n
MYSQL_USER=foronum
MYSQL_PASSWORD=cambia_esta_password
MYSQL_PORT=3306

# --- MySQL de Foronum (produccion) ---
# Descomentar y configurar para conectar a la BD real de Foronum
# FORONUM_MYSQL_HOST=tu-servidor-mysql.com
# FORONUM_MYSQL_PORT=3306
# FORONUM_MYSQL_DATABASE=foronum_prod
# FORONUM_MYSQL_USER=foronum_readonly
# FORONUM_MYSQL_PASSWORD=cambia_esta_password

# --- OpenAI API ---
# OPENAI_API_KEY=sk-...

# --- Email SMTP ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# NOTIFICATION_EMAIL=editorial@foronum.com
